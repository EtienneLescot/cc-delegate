# Clé API du provider ciblé par le worker. NE PAS committer votre vraie clé.
DELEGATE_API_KEY=

# Endpoint Anthropic-compatible du worker. Défaut actuel: MiniMax.
# International: https://api.minimax.io/anthropic  |  Chine: https://api.minimaxi.com/anthropic
DELEGATE_BASE_URL=https://api.minimax.io/anthropic

# Vérifier la chaîne exacte via GET /v1/models du provider choisi
DELEGATE_MODEL=MiniMax-M3[1m]

# Garde-fous
DELEGATE_MAX_TURNS=120
DELEGATE_MAX_BUDGET_USD=5
DELEGATE_TIMEOUT_MS=1800000
DELEGATE_API_TIMEOUT_MS=3000000

# Clé API du provider ciblé par le worker. NE PAS committer votre vraie clé.
DELEGATE_API_KEY=

# Modèle routé via litellm (worker/worker.py). Défaut actuel: MiniMax M3.
# Pour changer de provider : changez le préfixe litellm (voir
# https://docs.litellm.ai/docs/providers) ET la variable d'env ci-dessous.
DELEGATE_MODEL=litellm:minimax/MiniMax-M3

# Variable d'env que litellm lit pour DELEGATE_MODEL (ex: MINIMAX_API_KEY,
# OPENAI_API_KEY, ANTHROPIC_API_KEY...). Doit correspondre au provider choisi.
DELEGATE_API_KEY_ENV_VAR=MINIMAX_API_KEY

# Garde-fous
# Budget de pas LangGraph (compte chaque appel modèle/outil, pas des "tours")
DELEGATE_RECURSION_LIMIT=400
# Tentatives de RubricMiddleware avant d'abandonner la convergence
DELEGATE_RUBRIC_MAX_ITERATIONS=6
# Accepté mais pas encore appliqué en cours d'exécution (pas de compteur de coût natif)
DELEGATE_MAX_BUDGET_USD=5
DELEGATE_TIMEOUT_MS=1800000

# Clé API MiniMax (plateforme développeur MiniMax). NE PAS committer votre vraie clé.
MINIMAX_API_KEY=

# International: https://api.minimax.io/anthropic  |  Chine: https://api.minimaxi.com/anthropic
MINIMAX_BASE_URL=https://api.minimax.io/anthropic

# Vérifier la chaîne exacte via GET /v1/models
MINIMAX_MODEL=MiniMax-M3[1m]

# Garde-fous
MM_MAX_TURNS=120
MM_MAX_BUDGET_USD=5
MM_TIMEOUT_MS=1800000
MINIMAX_API_TIMEOUT_MS=3000000

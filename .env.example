# API key for the provider the worker targets. DO NOT commit your real key.
DELEGATE_API_KEY=

# Model routed through litellm (worker/worker.py). Current default: MiniMax M3.
# To switch provider: change the litellm prefix (see
# https://docs.litellm.ai/docs/providers) AND the env-var name below.
DELEGATE_MODEL=litellm:minimax/MiniMax-M3

# The env var litellm reads for DELEGATE_MODEL (e.g. MINIMAX_API_KEY,
# OPENAI_API_KEY, ANTHROPIC_API_KEY...). Must match the chosen provider.
DELEGATE_API_KEY_ENV_VAR=MINIMAX_API_KEY

# --- Guardrails ---
# LangGraph step budget (counts every model/tool call, not "turns").
DELEGATE_RECURSION_LIMIT=400
# RubricMiddleware attempts before giving up on convergence.
DELEGATE_RUBRIC_MAX_ITERATIONS=6
# Hard cost cap (USD). Enforced after every step: the run stops as soon as
# accumulated spend crosses it.
DELEGATE_MAX_BUDGET_USD=5
# Overall run timeout (ms). 1800000 = 30 min.
DELEGATE_TIMEOUT_MS=1800000
# Kill the worker if it goes silent this long (seconds); salvage still runs.
DELEGATE_STALL_TIMEOUT_S=300
# How long ask_supervisor/report_blocker wait for an answer (seconds) before
# the worker proceeds on its own best judgment.
DELEGATE_ASK_TIMEOUT_S=600

{
  "mcpServers": {
    "cc-delegate": {
      "command": "uv",
      "args": ["run", "${CLAUDE_PLUGIN_ROOT}/server/main.py"],
      "env": {
        "DELEGATE_API_KEY": "${DELEGATE_API_KEY}",
        "DELEGATE_MODEL": "litellm:minimax/MiniMax-M3",
        "DELEGATE_API_KEY_ENV_VAR": "MINIMAX_API_KEY"
      }
    }
  }
}
